{
  "manifest_version": 3,
  "name": "Dinosaur Eats",
  "version": "0.1.0",
  "description": "An April Fools extension where a tiny dinosaur eats webpage text line by line.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_title": "Dinosaur Eats",
    "default_icon": {
      "16": "icons/dino_extension_icon_16.png",
      "32": "icons/dino_extension_icon_32.png",
      "48": "icons/dino_extension_icon_48.png",
      "128": "icons/dino_extension_icon_128.png"
    }
  },
  "icons": {
    "16": "icons/dino_extension_icon_16.png",
    "32": "icons/dino_extension_icon_32.png",
    "48": "icons/dino_extension_icon_48.png",
    "128": "icons/dino_extension_icon_128.png"
  }
}
